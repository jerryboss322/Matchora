# ─── JPredict Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# On Vercel: add these in Project Settings > Environment Variables.

# ─── Football Data ─────────────────────────────────────────────────────────────
# Obtain at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ─── Odds API ──────────────────────────────────────────────────────────────────
# Obtain at: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# ─── Sportmonks ────────────────────────────────────────────────────────────────
# Supplemental fixture and league coverage.
# Obtain your API token at: https://my.sportmonks.com/api/tokens
SPORTMONKS_API_KEY=your_sportmonks_api_token_here

# ─── App URL ───────────────────────────────────────────────────────────────────
# Your deployment URL. Used for server-to-self API calls.
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Stats API (RapidAPI) ───────────────────────────────────────────────────────
# Match statistics: xG, shots, possession, passes, duels, discipline.
# Sign up at: https://rapidapi.com → search "API-Football"
# Subscribe to the free plan (100 requests/day)
STATS_API_KEY=your_rapidapi_key_here
STATS_API_HOST=free-api-live-football-data.p.rapidapi.com
